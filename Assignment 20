#include <stdio.h>

// Function for Call by Value (Does not change original values)
void swapByValue(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
    printf("Inside swapByValue function: a = %d, b = %d\n", a, b);
}

// Function for Call by Reference (Changes original values using pointers)
void swapByReference(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

int main() {
    int num1, num2;

    // Input
    printf("Enter two numbers: ");
    scanf("%d %d", &num1, &num2);

    int original_num1 = num1;
    int original_num2 = num2;

    printf("\n--- Call by Value ---\n");
    printf("Before swap: num1 = %d, num2 = %d\n", num1, num2);
    swapByValue(num1, num2);
    printf("After swap (in main): num1 = %d, num2 = %d\n", num1, num2);
    printf("Note: Original values remained unchanged.\n");

    // Resetting for the next demonstration
    num1 = original_num1;
    num2 = original_num2;

    printf("\n--- Call by Reference ---\n");
    printf("Before swap: num1 = %d, num2 = %d\n", num1, num2);
    swapByReference(&num1, &num2);
    printf("After swap (in main): num1 = %d, num2 = %d\n", num1, num2);
    printf("Note: Original values were successfully swapped.\n");

    return 0;
}
