#include <stdio.h>

int main() {
    int num, digit;

    printf("Enter an integer number: ");
    scanf("%d", &num);

    printf("Reverse order: ");

    // Handle the case where the input is 0
    if (num == 0) {
        printf("0");
    }

    // Loop to extract and print digits
    while (num != 0) {
        digit = num % 10;      // Get the last digit
        printf("%d", digit);   // Print the digit
        num = num / 10;        // Remove the last digit
    }

    printf("\n");

    return 0;
}

