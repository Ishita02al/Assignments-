#include <stdio.h>
#include <string.h>

// Define the structure
struct EMPLOYEE {
    char name[50];
    char designation[50];
    char gender[10];
    char doj[15];
    float salary;
};

// Function to display total employees
void displayTotal(int n) {
    printf("\na) Total number of employees: %d\n", n);
}

// Function to count male and female employees
void countGender(struct EMPLOYEE emp[], int n) {
    int male = 0, female = 0;
    for (int i = 0; i < n; i++) {
        if (strcasecmp(emp[i].gender, "Male") == 0) male++;
        else if (strcasecmp(emp[i].gender, "Female") == 0) female++;
    }
    printf("b) Count of male: %d, female: %d\n", male, female);
}

// Function to find employees with salary > 10,000
void highSalary(struct EMPLOYEE emp[], int n) {
    printf("c) Employees with salary > 10,000:\n");
    for (int i = 0; i < n; i++) {
        if (emp[i].salary > 10000) {
            printf("   - %s\n", emp[i].name);
        }
    }
}

// Function to find employees with designation "Asst Manager"
void findAsstManager(struct EMPLOYEE emp[], int n) {
    printf("d) Employees with designation 'Asst Manager':\n");
    for (int i = 0; i < n; i++) {
        if (strcasecmp(emp[i].designation, "AsstManager") == 0 || 
            strcasecmp(emp[i].designation, "Asst Manager") == 0) {
            printf("   - %s\n", emp[i].name);
        }
    }
}

int main() {
    int n;
    printf("Enter number of employees: ");
    scanf("%d", &n);

    struct EMPLOYEE emp;

    for (int i = 0; i < n; i++) {
        printf("\nEnter details for Employee %d:\n", i + 1);
        printf("Name: "); scanf("%s", emp[i].name);
        printf("Designation: "); scanf("%s", emp[i].designation);
        printf("Gender: "); scanf("%s", emp[i].gender);
        printf("Date of Joining (DD-MM-YYYY): "); scanf("%s", emp[i].doj);
        printf("Salary: "); scanf("%f", &emp[i].salary);
    }

    // Calling functions
    displayTotal(n);
    countGender(emp, n);
    highSalary(emp, n);
    findAsstManager(emp, n);

    return 0;
}

