#include <stdio.h>
#include <string.h>

int main() {
    char str1[100], str2[100], temp[100];
    int choice;

    printf("Enter the first string: ");
    fgets(str1, sizeof(str1), stdin);
    str1[strcspn(str1, "\n")] = 0; // Remove newline character

    printf("Enter the second string: ");
    fgets(str2, sizeof(str2), stdin);
    str2[strcspn(str2, "\n")] = 0; // Remove newline character

    do {
        printf("\n--- String Operations Menu ---");
        printf("\n1. Length of Strings");
        printf("\n2. Copy String 1 to String 2");
        printf("\n3. Concatenate Strings");
        printf("\n4. Compare Strings");
        printf("\n5. Reverse String 1");
        printf("\n6. Exit");
        printf("\nEnter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Length of String 1: %ld\n", strlen(str1));
                printf("Length of String 2: %ld\n", strlen(str2));
                break;
            case 2:
                strcpy(str2, str1);
                printf("String 2 is now: %s\n", str2);
                break;
            case 3:
                strcat(str1, str2);
                printf("Concatenated String: %s\n", str1);
                break;
            case 4:
                if (strcmp(str1, str2) == 0)
                    printf("Strings are equal.\n");
                else
                    printf("Strings are not equal.\n");
                break;
            case 5:
                printf("Original: %s\n", str1);
                // strrev is not standard in Linux/GCC; using manual loop
                int len = strlen(str1);
                for(int i = 0; i < len/2; i++) {
                    char t = str1[i];
                    str1[i] = str1[len-1-i];
                    str1[len-1-i] = t;
                }
                printf("Reversed: %s\n", str1);
                break;
            case 6:
                printf("Exiting...\n");
                break;
            default:
                printf("Invalid choice!\n");
        }
    } while (choice != 6);

    return 0;
}
