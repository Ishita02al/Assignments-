#include <stdio.h>
#include <math.h>

// Function to calculate factorial
long int factorial(int n) {
    long int fact = 1;
    for (int i = 1; i <= n; i++)
        fact *= i;
    return fact;
}

int main() {
    double x, sum = 0, term;
    int n, i, sign = 1;

    printf("Enter value of x (in radians): ");
    scanf("%lf", &x);
    printf("Enter number of terms: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++) {
        // The power for each term follows the sequence 1, 3, 5, 7... (2i + 1)
        int power = 2 * i + 1;
        
        term = sign * pow(x, power) / factorial(power);
        sum += term;
        
        // Alternate the sign for the next term
        sign *= -1;
    }

    printf("Sum of sine series = %lf\n", sum);

    return 0;
}

